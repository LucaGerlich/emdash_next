{
	"$schema": "./node_modules/@lunariajs/core/config.schema.json",
	"repository": {
		"name": "emdash-cms/emdash",
		"branch": "main"
	},
	"defaultLocale": {
		"label": "English",
		"lang": "en"
	},
	"locales": [
		{
			"label": "Español",
			"lang": "es"
		}
	],
	"files": [
		{
			"location": "packages/admin/src/locales/**/*.po",
			"pattern": "packages/admin/src/locales/@lang/messages.po",
			"type": "dictionary"
		}
	]
}
